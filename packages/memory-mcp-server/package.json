{
  "name": "@provos/memory-mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "Persistent memory MCP server with semantic search, LLM summarization, and automatic compaction",
  "license": "Apache-2.0",
  "author": "Niels Provos",
  "bin": {
    "memory-mcp-server": "./dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./prompts": "./dist/prompts.js"
  },
  "files": ["dist/"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e/",
    "benchmark": "npx tsx benchmark/run.ts --verbose",
    "benchmark:json": "npx tsx benchmark/run.ts --json",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.6.2",
    "sqlite-vec": "^0.1.7-alpha.2",
    "@huggingface/transformers": "^3.8.1",
    "openai": "^6.27.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "@types/better-sqlite3": "^7.6.13"
  }
}
