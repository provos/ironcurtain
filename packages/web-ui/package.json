{
  "name": "@provos/ironcurtain-web-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "mock-server": "tsx scripts/mock-ws-server.ts",
    "format": "prettier --write 'src/**/*.{ts,svelte}' 'scripts/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,svelte}' 'scripts/**/*.ts'",
    "lint": "eslint 'src/**/*.{ts,svelte}'",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.4.1",
    "autoprefixer": "^10.5.0",
    "eslint-plugin-svelte": "^3.19.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.14",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource/orbitron": "^5.2.8",
    "@types/dompurify": "^3.0.5",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "marked": "^15.0.12",
    "phosphor-svelte": "^3.1.0",
    "tailwind-merge": "^3.5.0"
  }
}
